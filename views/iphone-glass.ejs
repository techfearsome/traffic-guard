<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>iOS Firewall — Transaction Alert</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif;
    background: linear-gradient(145deg, #1c1c2e 0%, #2d1b4e 30%, #1a2744 60%, #0f1923 100%);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 0;
    position: relative;
  }
  body::before {
    content: ''; position: fixed; top: -50%; left: -50%; width: 200%; height: 200%;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(120,80,220,0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(40,100,200,0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .modal { margin: 0 16px; width: 100%; max-width: 420px; position: relative; z-index: 1; }

  .card {
    background: rgba(255,255,255,0.11);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border-radius: 22px;
    border: 0.5px solid rgba(255,255,255,0.18);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 0.5px 0 rgba(255,255,255,0.12);
  }

  .hdr { padding: 22px 22px 0; display: flex; align-items: center; gap: 14px; }

  .app-icon {
    width: 44px; height: 44px; border-radius: 12px;
    background: linear-gradient(145deg, #007AFF, #5856D6);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(0,122,255,0.4);
  }
  .app-icon svg { width: 22px; height: 22px; }

  .hdr-info h3 { font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.95); letter-spacing: -0.2px; }
  .hdr-info span { font-size: 12px; color: rgba(255,255,255,0.45); }

  .body { padding: 18px 22px 0; }

  .pill {
    background: rgba(255,179,64,0.15);
    border: 0.5px solid rgba(255,179,64,0.2);
    border-radius: 12px;
    padding: 12px 14px;
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 18px;
  }
  .pill .dot {
    width: 8px; height: 8px; border-radius: 50%; background: #FFB340;
    box-shadow: 0 0 8px rgba(255,179,64,0.6);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }
  .pill p { font-size: 13px; color: rgba(255,255,255,0.85); font-weight: 500; line-height: 1.3; }

  .txn {
    background: rgba(255,255,255,0.06);
    border-radius: 16px; padding: 20px;
    border: 0.5px solid rgba(255,255,255,0.07);
  }

  .amt-sec {
    text-align: center; padding-bottom: 16px; margin-bottom: 16px;
    border-bottom: 0.5px solid rgba(255,255,255,0.08);
  }
  .amt-sec small {
    font-size: 11px; color: rgba(255,255,255,0.4);
    text-transform: uppercase; letter-spacing: 1px; font-weight: 600;
    display: block; margin-bottom: 6px;
  }
  .amt {
    font-size: 40px; font-weight: 700; color: #FFF;
    letter-spacing: -1.5px; font-feature-settings: 'tnum';
  }

  .pay-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.1); border-radius: 8px;
    padding: 6px 12px; margin-top: 10px;
  }
  .pay-badge svg { width: 16px; height: 16px; }
  .pay-badge span { font-size: 12px; color: rgba(255,255,255,0.65); font-weight: 600; letter-spacing: 0.3px; }

  .row { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; }
  .row + .row { border-top: 0.5px solid rgba(255,255,255,0.06); }
  .row-l { font-size: 13px; color: rgba(255,255,255,0.4); }
  .row-v { font-size: 13px; color: rgba(255,255,255,0.9); font-weight: 500; }

  .question {
    font-size: 17px; font-weight: 600; color: rgba(255,255,255,0.95);
    text-align: center; padding: 22px 20px 10px; letter-spacing: -0.3px; line-height: 1.35;
  }

  .actions { padding: 14px 22px 22px; display: flex; flex-direction: column; gap: 10px; }

  .btn {
    width: 100%; padding: 16px; border: none; border-radius: 14px;
    font-size: 16px; font-weight: 600; letter-spacing: -0.2px;
    cursor: pointer; transition: all 0.2s; display: flex;
    align-items: center; justify-content: center; gap: 8px;
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .btn:active { transform: scale(0.97); opacity: 0.85; }
  .btn svg { width: 18px; height: 18px; }
  .btn-yes { background: #34C759; color: #fff; box-shadow: 0 4px 16px rgba(52,199,89,0.35); }
  .btn-no { background: rgba(255,59,48,0.9); color: #fff; box-shadow: 0 4px 16px rgba(255,59,48,0.3); }

  .footer { text-align: center; font-size: 11px; color: rgba(255,255,255,0.25); padding: 16px; }
  .home-bar {
    width: 134px; height: 5px; background: rgba(255,255,255,0.18);
    border-radius: 100px; margin: 16px auto 8px;
  }
</style>
</head>
<body>

<div class="modal">
  <div class="card">
    <div class="hdr">
      <div class="app-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <div class="hdr-info">
        <h3>iOS Firewall</h3>
        <span>Transaction Alert</span>
      </div>
    </div>
    <div class="body">
      <div class="pill">
        <div class="dot"></div>
        <p>New transaction detected — verification required</p>
      </div>
      <div class="txn">
        <div class="amt-sec">
          <small>Transaction Amount</small>
          <div class="amt">$149.00</div>
          <div class="pay-badge">
            <svg viewBox="0 0 24 24" fill="white"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span>Apple Pay</span>
          </div>
        </div>
        <div class="row"><span class="row-l">Merchant</span><span class="row-v">Amazon.com</span></div>
        <div class="row"><span class="row-l">Payment</span><span class="row-v">Apple Pay</span></div>
        <div class="row"><span class="row-l">Date & Time</span><span class="row-v">Feb 26, 2026 · 3:42 PM</span></div>
        <div class="row"><span class="row-l">Location</span><span class="row-v">Seattle, WA</span></div>
      </div>
      <p class="question">Did you authorize this transaction?</p>
    </div>
    <div class="actions">
      <button class="btn btn-yes" onclick="handleAction(this,'confirm')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Yes, This Was Me
      </button>
      <button class="btn btn-no" onclick="handleAction(this,'deny')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
        No, I Didn't Do This
      </button>
    </div>
  </div>
  <p class="footer">Secured by iOS Firewall · End-to-end encrypted</p>
  <div class="home-bar"></div>
</div>

<%- include('partials/support-modal') %>

</body>
</html>
