<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Traffic Guard — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Outfit', sans-serif;
    background: #07080a; color: #e2e8f0;
    min-height: 100vh;
  }

  /* ===== NAV ===== */
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(7,8,10,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding: 14px 24px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-left { display: flex; align-items: center; gap: 12px; }
  .nav-logo {
    width: 36px; height: 36px; border-radius: 10px;
    background: linear-gradient(135deg, rgba(139,92,246,0.2), rgba(59,130,246,0.12));
    border: 1px solid rgba(139,92,246,0.3);
    display: flex; align-items: center; justify-content: center;
  }
  .nav-logo svg { width: 18px; height: 18px; }
  .nav h1 { font-size: 16px; font-weight: 700; letter-spacing: -0.3px; }
  .nav-right { display: flex; align-items: center; gap: 12px; }
  .nav-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: rgba(139,92,246,0.6);
    background: rgba(139,92,246,0.08);
    border: 1px solid rgba(139,92,246,0.15);
    border-radius: 6px; padding: 4px 10px;
    text-transform: uppercase; letter-spacing: 1px;
  }
  .logout-btn {
    font-family: 'Outfit', sans-serif;
    font-size: 12px; color: rgba(255,255,255,0.4);
    background: none; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px; padding: 6px 14px;
    cursor: pointer; transition: all 0.2s;
    text-decoration: none;
  }
  .logout-btn:hover { color: #f87171; border-color: rgba(239,68,68,0.3); }

  .container { max-width: 1200px; margin: 0 auto; padding: 24px 20px; }

  /* ===== STAT CARDS ===== */
  .stats-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px; margin-bottom: 28px;
  }
  .stat-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px; padding: 18px 20px;
    position: relative; overflow: hidden;
  }
  .stat-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  }
  .stat-card.total::before { background: linear-gradient(90deg, transparent, rgba(139,92,246,0.5), transparent); }
  .stat-card.allowed::before { background: linear-gradient(90deg, transparent, rgba(16,185,129,0.5), transparent); }
  .stat-card.blocked::before { background: linear-gradient(90deg, transparent, rgba(239,68,68,0.5), transparent); }
  .stat-card.android::before { background: linear-gradient(90deg, transparent, rgba(16,185,129,0.5), transparent); }
  .stat-card.iphone::before { background: linear-gradient(90deg, transparent, rgba(59,130,246,0.5), transparent); }

  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: rgba(255,255,255,0.3);
    text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px;
  }
  .stat-value {
    font-size: 32px; font-weight: 800; letter-spacing: -1.5px;
  }
  .stat-card.total .stat-value { color: #a78bfa; }
  .stat-card.allowed .stat-value { color: #34d399; }
  .stat-card.blocked .stat-value { color: #f87171; }
  .stat-card.android .stat-value { color: #10b981; }
  .stat-card.iphone .stat-value { color: #3b82f6; }

  .stat-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: rgba(255,255,255,0.2); margin-top: 4px;
  }

  /* ===== SECONDARY STATS ===== */
  .secondary-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 14px; margin-bottom: 28px;
  }
  .info-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px; padding: 18px 20px;
  }
  .info-card h3 {
    font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.4);
    text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 14px;
  }
  .info-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .info-row:last-child { border-bottom: none; }
  .info-row-label { font-size: 13px; color: rgba(255,255,255,0.6); }
  .info-row-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: rgba(255,255,255,0.8); font-weight: 600;
  }

  /* ===== FILTER BAR ===== */
  .filter-bar {
    display: flex; align-items: center; gap: 10px;
    flex-wrap: wrap; margin-bottom: 18px;
  }
  .filter-btn {
    font-family: 'Outfit', sans-serif;
    font-size: 13px; font-weight: 500;
    padding: 8px 16px; border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.5);
    cursor: pointer; transition: all 0.2s;
    text-decoration: none;
  }
  .filter-btn:hover { border-color: rgba(139,92,246,0.3); color: rgba(255,255,255,0.8); }
  .filter-btn.active {
    background: rgba(139,92,246,0.12);
    border-color: rgba(139,92,246,0.3);
    color: #a78bfa;
  }

  .search-box {
    flex: 1; min-width: 200px;
  }
  .search-box form { display: flex; gap: 8px; }
  .search-box input {
    flex: 1; padding: 8px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px; color: #e2e8f0;
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    outline: none;
  }
  .search-box input:focus { border-color: rgba(139,92,246,0.4); }
  .search-box button {
    padding: 8px 14px; background: rgba(139,92,246,0.15);
    border: 1px solid rgba(139,92,246,0.25);
    border-radius: 10px; color: #a78bfa;
    font-family: 'Outfit', sans-serif; font-size: 12px; font-weight: 600;
    cursor: pointer;
  }

  /* ===== LOG TABLE ===== */
  .log-table-wrap {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px; overflow: hidden;
  }

  .log-table {
    width: 100%; border-collapse: collapse;
    font-size: 12px;
  }
  .log-table thead th {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 600;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase; letter-spacing: 1px;
    padding: 14px 12px; text-align: left;
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    white-space: nowrap;
  }
  .log-table tbody td {
    padding: 12px 12px; vertical-align: middle;
    border-bottom: 1px solid rgba(255,255,255,0.02);
    color: rgba(255,255,255,0.7);
    font-size: 12px;
    max-width: 200px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .log-table tbody tr:hover {
    background: rgba(255,255,255,0.02);
  }

  .badge {
    display: inline-block; padding: 3px 10px; border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .badge-allowed { background: rgba(16,185,129,0.12); color: #34d399; border: 1px solid rgba(16,185,129,0.2); }
  .badge-blocked { background: rgba(239,68,68,0.12); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }
  .badge-android { background: rgba(16,185,129,0.08); color: #10b981; }
  .badge-iphone { background: rgba(59,130,246,0.08); color: #3b82f6; }
  .badge-dummy { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3); }
  .badge-called { background: rgba(34,197,94,0.12); color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
  .badge-yes { background: rgba(251,191,36,0.12); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
  .badge-deny { background: rgba(249,115,22,0.12); color: #f97316; border: 1px solid rgba(249,115,22,0.2); }

  .ip-cell {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: rgba(255,255,255,0.6);
  }
  .reason-cell {
    font-size: 11px; color: rgba(239,68,68,0.7);
    max-width: 250px;
  }
  .time-cell {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: rgba(255,255,255,0.3);
    white-space: nowrap;
  }

  /* ===== PAGINATION ===== */
  .pagination {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; padding: 20px;
  }
  .page-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; padding: 8px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px; color: rgba(255,255,255,0.5);
    text-decoration: none; transition: all 0.2s;
  }
  .page-btn:hover { border-color: rgba(139,92,246,0.3); color: #a78bfa; }
  .page-btn.active { background: rgba(139,92,246,0.15); border-color: rgba(139,92,246,0.3); color: #a78bfa; }
  .page-btn.disabled { opacity: 0.3; pointer-events: none; }

  .page-info {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: rgba(255,255,255,0.25); padding: 0 10px;
  }

  /* ===== RESPONSIVE ===== */
  .table-scroll { overflow-x: auto; }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .stat-value { font-size: 24px; }
    .container { padding: 16px 12px; }
    .nav { padding: 12px 16px; }
    .nav h1 { font-size: 14px; }
  }

  /* Auto-refresh indicator */
  .refresh-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #10b981; display: inline-block;
    animation: blink 2s ease-in-out infinite;
    margin-right: 6px;
  }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
</style>
</head>
<body>

<!-- NAV -->
<div class="nav">
  <div class="nav-left">
    <div class="nav-logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <polyline points="9 12 11 14 15 10"/>
      </svg>
    </div>
    <h1>Traffic Guard</h1>
    <span class="nav-badge"><span class="refresh-dot"></span>Live</span>
  </div>
  <div class="nav-right">
    <a href="/dashboard/logout" class="logout-btn">Logout</a>
  </div>
</div>

<div class="container">

  <!-- STAT CARDS -->
  <div class="stats-grid">
    <div class="stat-card total">
      <div class="stat-label">Total (24h)</div>
      <div class="stat-value"><%= stats.h24.total %></div>
      <div class="stat-sub">7d: <%= stats.d7.total %></div>
    </div>
    <div class="stat-card allowed">
      <div class="stat-label">Allowed (24h)</div>
      <div class="stat-value"><%= stats.h24.allowed %></div>
      <div class="stat-sub"><%= stats.h24.total > 0 ? ((stats.h24.allowed / stats.h24.total) * 100).toFixed(1) : 0 %>%</div>
    </div>
    <div class="stat-card blocked">
      <div class="stat-label">Blocked (24h)</div>
      <div class="stat-value"><%= stats.h24.blocked %></div>
      <div class="stat-sub"><%= stats.h24.total > 0 ? ((stats.h24.blocked / stats.h24.total) * 100).toFixed(1) : 0 %>%</div>
    </div>
    <div class="stat-card android">
      <div class="stat-label">Android (24h)</div>
      <div class="stat-value"><%= stats.h24.android %></div>
    </div>
    <div class="stat-card iphone">
      <div class="stat-label">iPhone (24h)</div>
      <div class="stat-value"><%= stats.h24.iphone %></div>
    </div>
    <div class="stat-card" style="border-color: rgba(251,191,36,0.15);">
      <div class="stat-label">Btn Clicks (24h)</div>
      <div class="stat-value" style="color: #fbbf24;"><%= stats.h24.btnClicks %></div>
      <div class="stat-sub">Yes: <%= stats.h24.confirms %> / No: <%= stats.h24.denies %></div>
    </div>
    <div class="stat-card" style="border-color: rgba(34,197,94,0.15);">
      <div class="stat-label">Calls (24h)</div>
      <div class="stat-value" style="color: #22c55e;"><%= stats.h24.callClicks %></div>
      <div class="stat-sub"><%= stats.h24.btnClicks > 0 ? ((stats.h24.callClicks / stats.h24.btnClicks) * 100).toFixed(1) : 0 %>% of clicks</div>
    </div>
  </div>

  <!-- SECONDARY STATS -->
  <div class="secondary-grid">
    <div class="info-card">
      <h3>Top Countries (24h)</h3>
      <% if (stats.topCountries.length === 0) { %>
        <div class="info-row"><span class="info-row-label" style="color:rgba(255,255,255,0.2)">No data yet</span></div>
      <% } %>
      <% stats.topCountries.forEach(c => { %>
        <div class="info-row">
          <span class="info-row-label"><%= c._id %></span>
          <span class="info-row-value"><%= c.count %></span>
        </div>
      <% }); %>
    </div>
    <div class="info-card">
      <h3>Top Blocked ASNs (24h)</h3>
      <% if (stats.topASNs.length === 0) { %>
        <div class="info-row"><span class="info-row-label" style="color:rgba(255,255,255,0.2)">No data yet</span></div>
      <% } %>
      <% stats.topASNs.forEach(a => { %>
        <div class="info-row">
          <span class="info-row-label"><%= a._id %></span>
          <span class="info-row-value"><%= a.count %></span>
        </div>
      <% }); %>
    </div>
    <div class="info-card">
      <h3>Device Breakdown (24h)</h3>
      <% if (stats.deviceBreakdown.length === 0) { %>
        <div class="info-row"><span class="info-row-label" style="color:rgba(255,255,255,0.2)">No data yet</span></div>
      <% } %>
      <% stats.deviceBreakdown.forEach(d => { %>
        <div class="info-row">
          <span class="info-row-label"><%= d._id || 'Unknown' %></span>
          <span class="info-row-value"><%= d.count %></span>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <a href="/dashboard?filter=all" class="filter-btn <%= pagination.filter === 'all' ? 'active' : '' %>">All</a>
    <a href="/dashboard?filter=allowed" class="filter-btn <%= pagination.filter === 'allowed' ? 'active' : '' %>">✅ Allowed</a>
    <a href="/dashboard?filter=blocked" class="filter-btn <%= pagination.filter === 'blocked' ? 'active' : '' %>">🚫 Blocked</a>
    <div class="search-box">
      <form method="GET" action="/dashboard">
        <input type="hidden" name="filter" value="<%= pagination.filter %>">
        <input type="text" name="search" placeholder="Search IP, country, ASN, UTM..." value="<%= pagination.search %>">
        <button type="submit">Search</button>
      </form>
    </div>
  </div>

  <!-- LOG TABLE -->
  <div class="log-table-wrap">
    <div class="table-scroll">
      <table class="log-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Status</th>
            <th>IP</th>
            <th>Country</th>
            <th>ASN/Provider</th>
            <th>Type</th>
            <th>Device</th>
            <th>Served</th>
            <th>UTM Source</th>
            <th>Conversion</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody>
          <% if (logs.length === 0) { %>
            <tr><td colspan="11" style="text-align:center;padding:40px;color:rgba(255,255,255,0.2);">No traffic logs yet</td></tr>
          <% } %>
          <% logs.forEach(log => { %>
            <tr>
              <td class="time-cell">
                <%= new Date(log.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                <%= new Date(log.timestamp).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false }) %>
              </td>
              <td>
                <span class="badge badge-<%= log.status %>"><%= log.status %></span>
              </td>
              <td class="ip-cell"><%= log.ip %></td>
              <td><%= log.proxycheck?.country || '—' %></td>
              <td title="<%= log.proxycheck?.organisation || '' %>">
                <%= log.proxycheck?.organisation ? (log.proxycheck.organisation.length > 25 ? log.proxycheck.organisation.substring(0, 25) + '...' : log.proxycheck.organisation) : '—' %>
              </td>
              <td><%= log.proxycheck?.type || '—' %></td>
              <td>
                <% if (log.device?.os === 'android') { %>
                  <span class="badge badge-android">Android</span>
                <% } else if (log.device?.os === 'ios') { %>
                  <span class="badge badge-iphone">iPhone</span>
                <% } else { %>
                  <%= log.device?.os || '—' %>
                <% } %>
              </td>
              <td>
                <% if (log.contentServed === 'android') { %>
                  <span class="badge badge-android">Android</span>
                <% } else if (log.contentServed === 'iphone') { %>
                  <span class="badge badge-iphone">iPhone</span>
                <% } else { %>
                  <span class="badge badge-dummy">Dummy</span>
                <% } %>
              </td>
              <td><%= log.utm?.source || '—' %></td>
              <td>
                <% if (log.conversion?.callClicked) { %>
                  <span class="badge" style="background:rgba(34,197,94,0.12);color:#22c55e;border:1px solid rgba(34,197,94,0.2);">Called</span>
                <% } else if (log.conversion?.action === 'confirm') { %>
                  <span class="badge" style="background:rgba(251,191,36,0.12);color:#fbbf24;border:1px solid rgba(251,191,36,0.2);">Yes</span>
                <% } else if (log.conversion?.action === 'deny') { %>
                  <span class="badge" style="background:rgba(249,115,22,0.12);color:#f97316;border:1px solid rgba(249,115,22,0.2);">No</span>
                <% } else if (log.status === 'allowed') { %>
                  <span style="color:rgba(255,255,255,0.15);">—</span>
                <% } else { %>
                  <span style="color:rgba(255,255,255,0.08);">—</span>
                <% } %>
              </td>
              <td class="reason-cell" title="<%= log.blockReason || '' %>">
                <%= log.blockReason ? (log.blockReason.length > 40 ? log.blockReason.substring(0, 40) + '...' : log.blockReason) : '—' %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- PAGINATION -->
  <% if (pagination.totalPages > 1) { %>
    <div class="pagination">
      <a href="/dashboard?page=<%= pagination.page - 1 %>&filter=<%= pagination.filter %>&search=<%= pagination.search %>"
         class="page-btn <%= pagination.page <= 1 ? 'disabled' : '' %>">← Prev</a>

      <% for (let i = Math.max(1, pagination.page - 2); i <= Math.min(pagination.totalPages, pagination.page + 2); i++) { %>
        <a href="/dashboard?page=<%= i %>&filter=<%= pagination.filter %>&search=<%= pagination.search %>"
           class="page-btn <%= i === pagination.page ? 'active' : '' %>"><%= i %></a>
      <% } %>

      <span class="page-info"><%= pagination.totalLogs %> total</span>

      <a href="/dashboard?page=<%= pagination.page + 1 %>&filter=<%= pagination.filter %>&search=<%= pagination.search %>"
         class="page-btn <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">Next →</a>
    </div>
  <% } %>

</div>

<!-- Auto-refresh every 30s -->
<script>
  setTimeout(() => { window.location.reload(); }, 30000);
</script>

</body>
</html>
