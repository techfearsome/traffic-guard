<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Traffic Guard — Demo Mode</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Outfit', sans-serif;
    background: #07080a; color: #e2e8f0;
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
  }

  .demo-card {
    width: 100%; max-width: 480px;
  }

  .demo-header {
    text-align: center; margin-bottom: 36px;
  }

  .demo-badge {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 600;
    color: #f59e0b; background: rgba(245,158,11,0.1);
    border: 1px solid rgba(245,158,11,0.2);
    border-radius: 6px; padding: 4px 12px;
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 16px;
  }

  .demo-header h1 {
    font-size: 28px; font-weight: 800; letter-spacing: -0.5px;
    margin-bottom: 8px;
    background: linear-gradient(135deg, #a78bfa, #60a5fa);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .demo-header p {
    font-size: 14px; color: rgba(255,255,255,0.4); line-height: 1.5;
  }

  .pages-list {
    display: flex; flex-direction: column; gap: 12px;
  }

  .page-link {
    display: flex; align-items: center; gap: 16px;
    padding: 18px 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.25s;
    position: relative; overflow: hidden;
  }
  .page-link:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
    transform: translateY(-2px);
  }
  .page-link::before {
    content: ''; position: absolute; top: 0; left: 0; bottom: 0; width: 3px;
  }

  .page-link.android-neon::before { background: #10b981; }
  .page-link.android-material::before { background: #1A73E8; }
  .page-link.iphone-neon::before { background: #3b82f6; }
  .page-link.iphone-glass::before { background: #8b5cf6; }
  .page-link.dummy::before { background: rgba(255,255,255,0.15); }

  .page-num {
    width: 40px; height: 40px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px; font-weight: 700; flex-shrink: 0;
  }
  .android-neon .page-num { background: rgba(16,185,129,0.12); color: #34d399; }
  .android-material .page-num { background: rgba(26,115,232,0.12); color: #60a5fa; }
  .iphone-neon .page-num { background: rgba(59,130,246,0.12); color: #93c5fd; }
  .iphone-glass .page-num { background: rgba(139,92,246,0.12); color: #a78bfa; }
  .dummy .page-num { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3); }

  .page-info { flex: 1; }
  .page-info h3 {
    font-size: 15px; font-weight: 600; color: #e2e8f0;
    margin-bottom: 3px;
  }
  .page-info span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: rgba(255,255,255,0.3);
  }

  .page-arrow {
    font-size: 18px; color: rgba(255,255,255,0.2);
    transition: all 0.2s;
  }
  .page-link:hover .page-arrow {
    color: rgba(255,255,255,0.6);
    transform: translateX(4px);
  }

  .demo-footer {
    text-align: center; margin-top: 28px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: rgba(255,255,255,0.15);
    text-transform: uppercase; letter-spacing: 1.5px;
  }
  .demo-footer a {
    color: rgba(139,92,246,0.5); text-decoration: none;
  }
  .demo-footer a:hover { color: #a78bfa; }
</style>
</head>
<body>

<div class="demo-card">
  <div class="demo-header">
    <div class="demo-badge">⚠ Dev Mode</div>
    <h1>Traffic Guard</h1>
    <p>Preview all page designs without IP filtering or UTM checks. Click any page to view it.</p>
  </div>

  <div class="pages-list">
    <% pages.forEach(function(p, i) { %>
      <a href="/demo/<%= p.path %>" class="page-link <%= i === 0 ? 'android-neon' : i === 1 ? 'android-material' : i === 2 ? 'iphone-neon' : i === 3 ? 'iphone-glass' : 'dummy' %>">
        <div class="page-num"><%= p.path %></div>
        <div class="page-info">
          <h3><%= p.name %></h3>
          <span>/demo/<%= p.path %></span>
        </div>
        <div class="page-arrow">→</div>
      </a>
    <% }); %>
  </div>

  <div class="demo-footer">
    <a href="/dashboard">← Dashboard</a> · Demo mode active
  </div>
</div>

</body>
</html>
