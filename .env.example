# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/traffic-guard

# ProxyCheck.io API Key
PROXYCHECK_API_KEY=your-proxycheck-api-key-here

# Dashboard Login
DASHBOARD_PASS=your-secure-password-here

# Session Secret
SESSION_SECRET=your-random-session-secret-here

# Support Phone Number (shown after user clicks Yes/No)
SUPPORT_NUMBER=+18000000000

# Server Port
PORT=3000
